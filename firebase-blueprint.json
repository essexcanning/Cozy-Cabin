{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "worldId": { "type": "string" },
        "gender": { "type": "string" },
        "hairStyle": { "type": "string" },
        "hairColor": { "type": "string" },
        "skinColor": { "type": "string" },
        "eyeColor": { "type": "string" },
        "accessory": { "type": "string" },
        "facialFeature": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "World": {
      "title": "World",
      "description": "A shared world instance.",
      "type": "object",
      "properties": {
        "inviteCode": { "type": "string" },
        "ownerId": { "type": "string" },
        "partnerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "shared": {
          "type": "object",
          "properties": {
            "wood": { "type": "number" },
            "cozyCoins": { "type": "number" },
            "tasks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "text": { "type": "string" },
                  "completed": { "type": "boolean" }
                }
              }
            },
            "purchasedItems": {
              "type": "array",
              "items": { "type": "string" }
            },
            "dateNight": { "type": "string", "nullable": true },
            "lastInteractionAt": { "type": "number" }
          }
        }
      },
      "required": ["inviteCode", "ownerId", "createdAt"]
    },
    "Painting": {
      "title": "Painting",
      "description": "An AI-generated painting.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "data": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "x", "y", "data"]
    },
    "PlayerState": {
      "title": "PlayerState",
      "description": "The real-time state of a player in a world.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "scene": { "type": "string" },
        "facing": { "type": "string" },
        "isMoving": { "type": "boolean" },
        "animFrame": { "type": "number" },
        "color": { "type": "string" },
        "outfit": { "type": "string" },
        "gender": { "type": "string" },
        "hairStyle": { "type": "string" },
        "hairColor": { "type": "string" },
        "skinColor": { "type": "string" },
        "eyeColor": { "type": "string" },
        "accessory": { "type": "string" },
        "facialFeature": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "x", "y", "scene", "lastUpdated"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/worlds/{worldId}": {
      "schema": { "$ref": "#/entities/World" },
      "description": "Shared worlds."
    },
    "/worlds/{worldId}/players/{playerId}": {
      "schema": { "$ref": "#/entities/PlayerState" },
      "description": "Real-time player states in a world."
    },
    "/worlds/{worldId}/paintings/{paintingId}": {
      "schema": { "$ref": "#/entities/Painting" },
      "description": "AI-generated paintings in a world."
    }
  }
}
