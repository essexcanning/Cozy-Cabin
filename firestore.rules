rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // Domain Validators
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'displayName', 'email', 'worldId', 'gender', 'hairStyle', 'hairColor', 'skinColor', 'eyeColor', 'accessory', 'facialFeature']) &&
             request.resource.data.uid is string &&
             (!('email' in request.resource.data) || request.resource.data.email == null || request.resource.data.email is string) &&
             (!('displayName' in request.resource.data) || request.resource.data.displayName == null || request.resource.data.displayName is string) &&
             (!('worldId' in request.resource.data) || request.resource.data.worldId is string) &&
             (!('gender' in request.resource.data) || request.resource.data.gender is string) &&
             (!('hairStyle' in request.resource.data) || request.resource.data.hairStyle is string) &&
             (!('hairColor' in request.resource.data) || request.resource.data.hairColor is string) &&
             (!('skinColor' in request.resource.data) || request.resource.data.skinColor is string) &&
             (!('eyeColor' in request.resource.data) || request.resource.data.eyeColor is string) &&
             (!('accessory' in request.resource.data) || request.resource.data.accessory is string) &&
             (!('facialFeature' in request.resource.data) || request.resource.data.facialFeature is string);
    }
    
    function isValidWorld() {
      return hasOnlyAllowedFields(['inviteCode', 'ownerId', 'partnerId', 'createdAt', 'shared']) &&
             request.resource.data.inviteCode is string &&
             request.resource.data.inviteCode.size() == 6 &&
             request.resource.data.ownerId is string &&
             request.resource.data.createdAt is timestamp &&
             (!('partnerId' in request.resource.data) || request.resource.data.partnerId is string) &&
             (!('shared' in request.resource.data) || request.resource.data.shared is map);
    }
    
    function isValidPlayerState() {
      return hasOnlyAllowedFields(['uid', 'x', 'y', 'scene', 'facing', 'isMoving', 'animFrame', 'color', 'outfit', 'gender', 'hairStyle', 'hairColor', 'skinColor', 'eyeColor', 'accessory', 'facialFeature', 'lastUpdated']) &&
             request.resource.data.uid is string &&
             request.resource.data.x is number &&
             request.resource.data.y is number &&
             request.resource.data.scene is string &&
             (!('facing' in request.resource.data) || request.resource.data.facing is string) &&
             (!('isMoving' in request.resource.data) || request.resource.data.isMoving is bool) &&
             (!('animFrame' in request.resource.data) || request.resource.data.animFrame is number) &&
             (!('color' in request.resource.data) || request.resource.data.color is string) &&
             (!('outfit' in request.resource.data) || request.resource.data.outfit is string) &&
             (!('gender' in request.resource.data) || request.resource.data.gender is string) &&
             (!('hairStyle' in request.resource.data) || request.resource.data.hairStyle is string) &&
             (!('hairColor' in request.resource.data) || request.resource.data.hairColor is string) &&
             (!('skinColor' in request.resource.data) || request.resource.data.skinColor is string) &&
             (!('eyeColor' in request.resource.data) || request.resource.data.eyeColor is string) &&
             (!('accessory' in request.resource.data) || request.resource.data.accessory is string) &&
             (!('facialFeature' in request.resource.data) || request.resource.data.facialFeature is string) &&
             (!('lastUpdated' in request.resource.data) || request.resource.data.lastUpdated is timestamp);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser() && uidNotModified();
    }
    
    match /worlds/{worldId} {
      // Allow read if you are the owner or partner, or if you're trying to join (we can allow read if authenticated for joining via invite code)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidWorld() && request.resource.data.ownerId == request.auth.uid;
      // Allow update if owner or partner, or if joining (partnerId is being set)
      allow update: if isAuthenticated() && isValidWorld() && 
                    (resource.data.ownerId == request.auth.uid || 
                     resource.data.partnerId == request.auth.uid || 
                     (!('partnerId' in resource.data) && request.resource.data.partnerId == request.auth.uid));
                     
      match /players/{playerId} {
        // Anyone in the world can read player states
        allow read: if isAuthenticated();
        // A player can only write their own state
        allow create, update: if isOwner(playerId);
        allow delete: if isOwner(playerId);
      }
    }
  }
}
